{
  "rules": {
    "desktop": {
      ".read": true,
      ".write": "auth != null" 
    },
    "desktop-events": {
      ".read": "auth != null",
      ".write": false, // Bloquear escrita direta no nó principal
      "$eventId": {
        // Permitir que usuários autenticados adicionem novos eventos
        ".write": "!data.exists() && auth != null",
        ".validate": "newData.hasChildren(['type', 'payload', 'timestamp'])",
        "type": {
          ".validate": "newData.isString()"
        },
        "payload": {
          ".validate": "newData.isObject()"
        },
        "timestamp":{
          ".validate": "newData.isNumber()"
        }
      }
    },
    "system": {
      ".read": true,
      ".write": false
    },
    "cursors": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      },
      ".indexOn": ["lastActive"]
    }
  }
}
